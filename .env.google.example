# Google Reviews widget (Places API — New)
# 1. Enable "Places API (New)" in Google Cloud Console
# 2. Create an API key and restrict it to Places API (New)
# 3. Add these to Services/.env and Vercel environment variables

GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Optional: set if auto-search picks the wrong listing
# GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxx

# Used when GOOGLE_PLACE_ID is not set
GOOGLE_PLACE_SEARCH_QUERY=River Signs and Print Unit D2 Warelands Way Middlesbrough TS4 2JY

# Public link shown in the widget (your Google review/share URL)
GOOGLE_REVIEWS_URL=https://share.google/vANleAmxbXBYeeSkp
