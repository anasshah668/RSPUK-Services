# Worldpay — copy these lines into backend/.env and replace placeholders.
# Switch sandbox vs production with WORLDPAY_ENVIRONMENT only (try | live).

WORLDPAY_ENVIRONMENT=try

# --- Sandbox (Try) — from Worldpay Access / Implementation Manager ---
WORLDPAY_TRY_CHECKOUT_ID=
WORLDPAY_TRY_USERNAME=
WORLDPAY_TRY_PASSWORD=
WORLDPAY_TRY_ENTITY=default

# --- Production (Live) — fill before going live; then set WORLDPAY_ENVIRONMENT=live ---
WORLDPAY_LIVE_CHECKOUT_ID=
WORLDPAY_LIVE_USERNAME=
WORLDPAY_LIVE_PASSWORD=
WORLDPAY_LIVE_ENTITY=

# Optional: use instead of *_PASSWORD for Basic auth if your portal labels the secret “service key”
# WORLDPAY_TRY_SERVICE_KEY=
# WORLDPAY_LIVE_SERVICE_KEY=

# If the SDK returns only a session token (not a full URL), we build:
#   {apiBase}/{prefix}/{token}
# Default prefix matches Worldpay session URLs (override if your SDK uses /sessions/... only).
# WORLDPAY_CHECKOUT_SESSION_PATH_PREFIX=verifiedTokens/sessions

# Card statement descriptor (max 24 chars for line1)
# WORLDPAY_STATEMENT_LINE1=RSPUK Order

# Authorize: default path /payments/authorizations uses Card Payments v6 media types (auto).
# v7 uses /cardPayments/customerInitiatedTransactions — set path + version is inferred.
# WORLDPAY_AUTHORIZATION_PATH=/payments/authorizations
# WORLDPAY_AUTHORIZATION_PATH=/cardPayments/customerInitiatedTransactions
# WORLDPAY_AUTH_API=card
# WORLDPAY_CARD_PAYMENTS_VERSION=

# Optional overrides (defaults match Try/Live automatically)
# WORLDPAY_API_BASE_URL=https://try.access.worldpay.com
# WORLDPAY_AUTHORIZATION_PATH=/payments/authorizations
# WORLDPAY_API_VERSION=2024-06-01

# Bearer only if your Worldpay documentation says so (uses active profile *_SERVICE_KEY)
# WORLDPAY_AUTH_SCHEME=Bearer
